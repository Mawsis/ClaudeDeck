# Copy to deploy/.env and fill in. Generate tokens with:
#   openssl rand -hex 32
SLOPDECK_HOOK_TOKEN=
SLOPDECK_DECK_TOKEN=

# VPS: your domain, e.g. deck.example.com (Caddy provisions HTTPS automatically).
# Local smoke test: ":80" plus CADDY_HTTP_PORT to avoid clashing with local services.
DECK_DOMAIN=
#CADDY_HTTP_PORT=80
#CADDY_HTTPS_PORT=443

# Optional: Web Push completion alerts while the phone is locked/backgrounded.
# Generate the key pair with:
#   npx web-push generate-vapid-keys
# Set all three or none; the subject is a contact URI (mailto: or https:).
#SLOPDECK_VAPID_PUBLIC_KEY=
#SLOPDECK_VAPID_PRIVATE_KEY=
#SLOPDECK_VAPID_SUBJECT=mailto:you@example.com

# Optional: turns shorter than this never alert (milliseconds, default 45000).
#SLOPDECK_ALERT_THRESHOLD_MS=45000

# Optional: how long an intercepted AskUserQuestion waits for a deck answer
# before falling back to the terminal (milliseconds, default 60000).
#SLOPDECK_QUESTION_TIMEOUT_MS=60000
