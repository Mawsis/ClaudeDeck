# Copy to deploy/.env and fill in.
#
# --- Base (Caddy) deploy: static-token workspace ---
# Optional now. Set both to run one pre-seeded, static-token workspace (legacy
# compatibility); leave both empty for a mint-only gateway. Generate with:
#   openssl rand -hex 32
SLOPDECK_HOOK_TOKEN=
SLOPDECK_DECK_TOKEN=

# --- Hosted (mps) override: mint-only, persistent, behind Dokploy Traefik ---
# Used only with `-f docker-compose.mps.yml`. Leave HOOK/DECK tokens empty above.
# Persistent SQLite path on the mounted volume (the override sets this; here
# for reference/local overrides).
#SLOPDECK_DB_PATH=/data/slopdeck.sqlite
# IP rate limit on the public mint endpoint (defaults: 10 per 60000ms).
#SLOPDECK_MINT_RATE_MAX=10
#SLOPDECK_MINT_RATE_WINDOW_MS=60000
# Inactivity TTL after which an unclaimed anonymous workspace is swept (7d).
#SLOPDECK_EPHEMERAL_TTL_MS=604800000
# Traefik routing (override defaults shown). Match your shared Traefik.
#SLOPDECK_DOMAIN=slopdeck.mawsis.dev
#SLOPDECK_TRAEFIK_ENTRYPOINT=websecure
#SLOPDECK_TRAEFIK_CERTRESOLVER=letsencrypt

# VPS: your domain, e.g. deck.example.com (Caddy provisions HTTPS automatically).
# Local smoke test: ":80" plus CADDY_HTTP_PORT to avoid clashing with local services.
DECK_DOMAIN=
#CADDY_HTTP_PORT=80
#CADDY_HTTPS_PORT=443

# Optional: Web Push completion alerts while the phone is locked/backgrounded.
# Generate the key pair with:
#   npx web-push generate-vapid-keys
# Set all three or none; the subject is a contact URI (mailto: or https:).
#SLOPDECK_VAPID_PUBLIC_KEY=
#SLOPDECK_VAPID_PRIVATE_KEY=
#SLOPDECK_VAPID_SUBJECT=mailto:you@example.com

# Optional: turns shorter than this never alert (milliseconds, default 45000).
#SLOPDECK_ALERT_THRESHOLD_MS=45000

# Optional: how long an intercepted AskUserQuestion waits for a deck answer
# before falling back to the terminal (milliseconds, default 60000).
#SLOPDECK_QUESTION_TIMEOUT_MS=60000
