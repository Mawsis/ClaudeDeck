{
  "name": "slopdeck",
  "version": "0.2.1",
  "type": "module",
  "description": "Ambient phone-as-deck companion + remote permission control for Claude Code",
  "keywords": [
    "claude-code",
    "claude",
    "cli",
    "permissions",
    "hooks",
    "deck",
    "pwa",
    "notifications"
  ],
  "homepage": "https://github.com/Mawsis/ClaudeDeck#readme",
  "bugs": {
    "url": "https://github.com/Mawsis/ClaudeDeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mawsis/ClaudeDeck.git"
  },
  "license": "MIT",
  "author": "Mawsis",
  "bin": {
    "slopdeck": "./bin/slopdeck.js"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/gateway/index.ts",
    "start": "node --experimental-strip-types src/gateway/index.ts",
    "generate-config": "node --experimental-strip-types src/config-generator/cli.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-pwa.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "canary": "SLOPDECK_CANARY=1 vitest run test/canary.askuserquestion.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.0",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@types/node": "^22.15.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
